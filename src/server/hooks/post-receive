#!/usr/bin/env bash

HOOK_FILE="$(readlink -f "$0")"
SCRIPT_DIR="$(cd "$(dirname "$HOOK_FILE")" && pwd)"

PROJECT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
WORK_DIR="$PROJECT_DIR/src/code"

INPUT_NOTES_REF="commits"
OUTPUT_NOTES_REF="testAuditor"

while read -r oldrev newrev refname; do
    [[ "$refname" == refs/notes/* ]] && continue

    note="$(git notes --ref="$INPUT_NOTES_REF" show "$newrev" 2>/dev/null || true)"
    if [[ -z "$note" ]]; then
        echo "Error: No git note found for $newrev"
        continue
    fi

    if ! output="$(cd "$WORK_DIR" && nix develop "$PROJECT_DIR" --command testAuditor -c "$note")"; then
        echo "Error: testAuditor failed for $newrev"
        continue
    fi

    if [[ -z "$output" ]]; then
        echo "testAuditor produced no output for $newrev; no note written"
        continue
    fi

    git notes --ref="$OUTPUT_NOTES_REF" add -f -m "$output" "$newrev"

    echo "testAuditor wrote note to refs/notes/$OUTPUT_NOTES_REF for $newrev"
done